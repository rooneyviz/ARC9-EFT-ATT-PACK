"VertexLitGeneric"
{
	"$basetexture" "models/weapons/arc9/darsu_eft/mods\magwell_rcm_d"
	"$bumpmap" "models/weapons/arc9/darsu_eft/mods\magwell_rcm_n"
	"$phongexponenttexture" "models/weapons/arc9/darsu_eft/mods\nil_m"
	
	
	"$metal" "1"
	"$roughnessmultiplier" "1"
	"$phong" "1"
	"$phongboost" ".1"
	"$phongalbedotint" "1"
	"$phongfresnelranges" "[0.5 1 1]"
	"$color2" "[.8 .8 .8]"

	"$fuzz" "1"
	"$fuzzmultiplier" ".2"
	
	"$envmap" "env_cubemap"
	// "$srgbtint" "[1.5 1.5 1.5]"
	
	"$nocull" "1"
 Proxies {
    CustomCamo {
        camoTexture $detail
        camoScale $detailscale
        blend $detailblendfactor
    }
}

